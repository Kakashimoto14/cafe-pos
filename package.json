{
  "name": "cafe-pos",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/frontend",
    "packages/shared-types",
    "packages/ui-kit"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend \"npm run dev:backend\" \"npm run dev:frontend\"",
    "dev:backend": "cd apps\\backend && ..\\..\\tools\\php\\php.exe -S 127.0.0.1:8000 -t public",
    "dev:frontend": "npm run dev --workspace @cafe/frontend",
    "migrate:backend": "cd apps\\backend && ..\\..\\tools\\php\\php.exe artisan migrate --force",
    "build:frontend": "npm run build --workspace @cafe/frontend",
    "test:frontend": "npm run test --workspace @cafe/frontend",
    "test:backend": "cd apps\\backend && ..\\..\\tools\\php\\php.exe vendor\\bin\\pest"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
